<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Amplify.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:Amplify.App.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,10,24,0">
        <!--
            A Grid wrapping the MaxWidth StackPanel avoids a known SettingsExpander layout glitch when
            a MaxWidth is set directly on the items' parent panel.
        -->
        <Grid>
            <StackPanel
                MaxWidth="800"
                HorizontalAlignment="Stretch"
                Spacing="4">

                <!-- The screen title and its back button live in the window title bar (see MainWindow). -->

                <!-- General -->
                <controls:SectionHeader x:Uid="Settings_General_Header"  />
                <!--
                    Launch-at-startup and start-minimized are one connected group: start-minimized only
                    takes effect when the app launches at startup, so it sits indented beneath the launch
                    toggle as its child and is disabled whenever launch-at-startup is off. The two cards
                    share squared inner corners and overlap by a pixel so they read as a single unit
                    (always visible — deliberately not a collapsible expander).
                -->
                <StackPanel Spacing="0">
                    <tk:SettingsCard x:Uid="Settings_LaunchStartup" CornerRadius="4,4,0,0">
                        <tk:SettingsCard.HeaderIcon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE7E8;" />
                        </tk:SettingsCard.HeaderIcon>
                        <ToggleSwitch
                            IsEnabled="{x:Bind ViewModel.LaunchAtStartupConfigurable, Mode=OneWay}"
                            IsOn="{x:Bind ViewModel.LaunchAtStartup, Mode=TwoWay}" />
                    </tk:SettingsCard>
                    <tk:SettingsCard
                        x:Uid="Settings_StartMinimized"
                        Margin="0,-1,0,0"
                        CornerRadius="0,0,4,4"
                        IsEnabled="{x:Bind ViewModel.LaunchAtStartup, Mode=OneWay}">
                        <tk:SettingsCard.Resources>
                            <x:Double x:Key="SettingsCardLeftIndention">40</x:Double>
                        </tk:SettingsCard.Resources>
                        <tk:SettingsCard.HeaderIcon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE708;" />
                        </tk:SettingsCard.HeaderIcon>
                        <ToggleSwitch IsOn="{x:Bind ViewModel.StartMinimizedToTray, Mode=TwoWay}" />
                    </tk:SettingsCard>
                </StackPanel>
                <tk:SettingsCard x:Uid="Settings_CloseToTray">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8BB;" />
                    </tk:SettingsCard.HeaderIcon>
                    <ToggleSwitch IsOn="{x:Bind ViewModel.MinimizeToTrayOnClose, Mode=TwoWay}" />
                </tk:SettingsCard>

                <!-- Appearance -->
                <controls:SectionHeader x:Uid="Settings_Appearance_Header" />
                <tk:SettingsCard x:Uid="Settings_Theme">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE771;" />
                    </tk:SettingsCard.HeaderIcon>
                    <ComboBox
                        MinWidth="138"
                        SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}">
                        <ComboBoxItem x:Uid="Settings_Theme_System" />
                        <ComboBoxItem x:Uid="Settings_Theme_Light" />
                        <ComboBoxItem x:Uid="Settings_Theme_Dark" />
                    </ComboBox>
                </tk:SettingsCard>

                <!-- Volume -->
                <controls:SectionHeader x:Uid="Settings_Volume_Header" />
                <!-- The slider is wide, so this card always lays its content out below the header. -->
                <tk:SettingsCard
                    x:Uid="Settings_VolumeStep"
                    ContentAlignment="Vertical"
                    HorizontalContentAlignment="Stretch">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE767;" />
                    </tk:SettingsCard.HeaderIcon>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Slider
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Maximum="25"
                            Minimum="1"
                            StepFrequency="1"
                            Value="{x:Bind ViewModel.VolumeStepValue, Mode=TwoWay}" />
                        <TextBlock
                            Grid.Column="1"
                            MinWidth="36"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="{x:Bind ViewModel.VolumeStepDisplay, Mode=OneWay}" />
                    </Grid>
                </tk:SettingsCard>

                <!-- Account -->
                <controls:SectionHeader x:Uid="Settings_Account_Header" />
                <tk:SettingsCard Header="{x:Bind ViewModel.AccountTitle, Mode=OneWay}">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE77B;" />
                    </tk:SettingsCard.HeaderIcon>
                    <StackPanel
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="10">
                        <Button
                            x:Uid="Settings_Account_Disconnect"
                            Command="{x:Bind ViewModel.DisconnectCommand}"
                            Visibility="{x:Bind ViewModel.IsConnected, Mode=OneWay}" />
                        <Button
                            x:Uid="Settings_Account_Reconnect"
                            Command="{x:Bind ViewModel.ReconnectCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            Visibility="{x:Bind ViewModel.IsNotConnected, Mode=OneWay}" />
                    </StackPanel>
                </tk:SettingsCard>
                <tk:SettingsCard x:Uid="Settings_ClientId">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE72E;" />
                    </tk:SettingsCard.HeaderIcon>
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        IsTextSelectionEnabled="True"
                        Text="{x:Bind ViewModel.SpotifyClientIdDisplay, Mode=OneWay}" />
                </tk:SettingsCard>

                <!-- Reset -->
                <controls:SectionHeader x:Uid="Settings_Reset_Header" />
                <tk:SettingsCard x:Uid="Settings_Reset">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE894;" />
                    </tk:SettingsCard.HeaderIcon>
                    <!-- Opens a confirmation dialog first; the reset only runs on explicit confirm. -->
                    <Button x:Uid="Settings_Reset_Button" Click="OnResetClick" />
                </tk:SettingsCard>

                <!-- Footer: the brand links to the repo; version + affiliation follow as plain text. -->
                <TextBlock
                    Margin="0,16,0,16"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    TextAlignment="Center"
                    TextWrapping="Wrap">
                    <Hyperlink NavigateUri="https://github.com/chrisgid/Amplify"><Run x:Uid="Settings_Footer_Brand" /></Hyperlink><Run Text="{x:Bind ViewModel.FooterText}" />
                </TextBlock>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
