<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Amplify.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24">
        <StackPanel
            MaxWidth="420"
            HorizontalAlignment="Stretch"
            Spacing="16">
            <StackPanel
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    Click="OnBackClick"
                    AutomationProperties.Name="Back"
                    Style="{StaticResource SubtleButtonStyle}"
                    ToolTipService.ToolTip="Back">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE72B;" />
                </Button>
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="Settings" />
            </StackPanel>

            <!--
                Placeholder. The real settings (general, appearance, volume step, account, reset) and
                the persistence layer behind them land with their own feature; for now this screen
                only demonstrates routing back to the main screen.
            -->
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource BodyTextBlockStyle}"
                Text="Settings will appear here."
                TextWrapping="Wrap" />

            <TextBlock
                x:Name="VersionText"
                Margin="0,8,0,0"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}" />
        </StackPanel>
    </ScrollViewer>
</Page>
