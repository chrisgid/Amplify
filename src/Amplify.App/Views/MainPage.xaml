<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Amplify.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:Amplify.App.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Small 32x32 square nudge button: the default button chrome (fill + border at rest), just
             sized down with no padding so the glyph stays centred. -->
        <Style
            x:Key="VolumeNudgeButtonStyle"
            BasedOn="{StaticResource DefaultButtonStyle}"
            TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <!-- Hotkey status line: the caption style bumped to 14 so the hint/conflict message reads a
             little larger than the other captions (which stay at the default caption size). -->
        <Style
            x:Key="StatusLineTextBlockStyle"
            BasedOn="{StaticResource CaptionTextBlockStyle}"
            TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
        </Style>

        <!-- One keycap in a hotkey combination, e.g. "Ctrl" or "↑". -->
        <DataTemplate x:Key="KeycapTemplate" x:DataType="x:String">
            <Border
                MinWidth="28"
                Height="28"
                Padding="7,0"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind}" />
            </Border>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer Padding="24,10,24,0">
        <Grid>
            <StackPanel
                MaxWidth="800"
                HorizontalAlignment="Stretch"
                Spacing="4">

                <!-- Spotify section: the title, connected-status card, and volume control grouped
                     together (the volume card sits directly beneath the status card). -->
                <StackPanel Spacing="4">

                    <!-- Section title only (no subtitle). -->
                    <controls:SectionHeader x:Uid="Volume_SectionTitle" />

                    <!-- Connected status card -->
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Visibility="{x:Bind StatusViewModel.ShowConnectedCard, Mode=OneWay}">
                        <Grid ColumnSpacing="13">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="0"
                                Width="38"
                                Height="38"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="19">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                    Text="{x:Bind StatusViewModel.Account.Initials, Mode=OneWay}" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Left"
                                    MaxWidth="220"
                                    Style="{StaticResource BodyTextBlockStyle}"
                                    Text="{x:Bind StatusViewModel.Account.DisplayName, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind StatusViewModel.DeviceLineText, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <!-- The success check sits with the "Connected" label. -->
                            <StackPanel
                                Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="4">
                                
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                    Style="{StaticResource BodyTextBlockStyle}"
                                    Text="{x:Bind StatusViewModel.ConnectedLabelText, Mode=OneWay}" />
                                <FontIcon
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                    Glyph="&#xE73E;" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--
                        Volume card: a native SettingsCard matching the hotkey rows — "Volume" header, the
                        live percentage as its description, and the slider with step nudge buttons as its
                        content. Disabled (which dims it natively) whenever there is nothing to control; the
                        status card above owns the "no active device" message.
                    -->
                    <tk:SettingsCard
                        x:Uid="Volume_Header"
                        ContentAlignment="Vertical"
                        Description="{x:Bind VolumeViewModel.VolumeText, Mode=OneWay}"
                        HorizontalContentAlignment="Stretch"
                        IsEnabled="{x:Bind VolumeViewModel.CanControl, Mode=OneWay}">
                        <!-- Vertical alignment always stacks the slider row beneath the header; the row
                             stretches full width so the slider fills the space between the nudge buttons. -->
                        <Grid HorizontalAlignment="Stretch" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Command="{x:Bind VolumeViewModel.NudgeDownCommand}"
                                Style="{StaticResource VolumeNudgeButtonStyle}"
                                ToolTipService.ToolTip="Volume down">
                                <FontIcon
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    FontSize="16"
                                    Glyph="&#xF8AB;" />
                            </Button>
                            <Slider
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                Maximum="100"
                                Minimum="0"
                                Value="{x:Bind VolumeViewModel.SliderValue, Mode=TwoWay}" />
                            <Button
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Command="{x:Bind VolumeViewModel.NudgeUpCommand}"
                                Style="{StaticResource VolumeNudgeButtonStyle}"
                                ToolTipService.ToolTip="Volume up">
                                <FontIcon
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    FontSize="16"
                                    Glyph="&#xF8AA;" />
                            </Button>
                        </Grid>
                    </tk:SettingsCard>
                </StackPanel>

                <!-- Connecting -->
                <InfoBar
                    x:Uid="Status_Connecting"
                    IsClosable="False"
                    IsOpen="{x:Bind StatusViewModel.IsConnecting, Mode=OneWay}"
                    Severity="Informational"
                    Visibility="{x:Bind StatusViewModel.IsConnecting, Mode=OneWay}" />

                <!-- Error -->
                <InfoBar
                    x:Uid="Status_Error"
                    IsClosable="False"
                    IsOpen="{x:Bind StatusViewModel.IsError, Mode=OneWay}"
                    Severity="Error"
                    Visibility="{x:Bind StatusViewModel.IsError, Mode=OneWay}">
                    <InfoBar.ActionButton>
                        <Button
                            x:Uid="Status_Error_Reconnect"
                            Command="{x:Bind StatusViewModel.ReconnectCommand}" />
                    </InfoBar.ActionButton>
                </InfoBar>

                <!-- Keyboard shortcuts: two rebindable rows in cards, headed by the title + shared
                     status line (hint/prompt, or a conflict message). -->
                <StackPanel Spacing="4">
                    <controls:SectionHeader x:Uid="Hotkey_SectionTitle">
                        <!-- Subtitle: the shared status line — secondary for hint/prompt, caution for a
                             conflict message (only one shows at a time). -->
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,1,0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource StatusLineTextBlockStyle}"
                                Text="{x:Bind HotkeysViewModel.StatusLineText, Mode=OneWay}"
                                TextWrapping="Wrap"
                                Visibility="{x:Bind HotkeysViewModel.StatusLineIsNormal, Mode=OneWay}" />
                            <TextBlock
                                Margin="0,0,1,0"
                                Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                Style="{StaticResource StatusLineTextBlockStyle}"
                                Text="{x:Bind HotkeysViewModel.StatusLineText, Mode=OneWay}"
                                TextWrapping="Wrap"
                                Visibility="{x:Bind HotkeysViewModel.StatusLineIsCaution, Mode=OneWay}" />
                        </StackPanel>
                    </controls:SectionHeader>

                    <tk:SettingsCard
                        Description="{x:Bind HotkeysViewModel.Up.SubText, Mode=OneWay}"
                        Header="{x:Bind HotkeysViewModel.Up.ActionLabel}">
                        <tk:SettingsCard.HeaderIcon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE995;" />
                        </tk:SettingsCard.HeaderIcon>
                        <!-- Focusable, non-button host so combo keys (incl. Space/Enter) don't activate anything. -->
                        <ContentControl
                            x:Name="UpHotkeyRow"
                            IsTabStop="True"
                            KeyDown="OnRowKeyDown"
                            LostFocus="OnRowLostFocus"
                            Tag="{x:Bind HotkeysViewModel.Up}"
                            UseSystemFocusVisuals="False">
                            <StackPanel
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="8">
                                <ItemsControl
                                    ItemTemplate="{StaticResource KeycapTemplate}"
                                    ItemsSource="{x:Bind HotkeysViewModel.Up.DisplayTokens, Mode=OneWay}"
                                    Visibility="{x:Bind HotkeysViewModel.Up.ShowKeycaps, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                                <TextBlock
                                    x:Uid="Hotkey_Listening"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Visibility="{x:Bind HotkeysViewModel.Up.IsRecording, Mode=OneWay}" />
                                <Button Click="OnUpEditClick" ToolTipService.ToolTip="Change shortcut">
                                    <FontIcon
                                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                                        FontSize="14"
                                        Glyph="&#xE70F;" />
                                </Button>
                            </StackPanel>
                        </ContentControl>
                    </tk:SettingsCard>

                    <tk:SettingsCard
                        Description="{x:Bind HotkeysViewModel.Down.SubText, Mode=OneWay}"
                        Header="{x:Bind HotkeysViewModel.Down.ActionLabel}">
                        <tk:SettingsCard.HeaderIcon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE993;" />
                        </tk:SettingsCard.HeaderIcon>
                        <ContentControl
                            x:Name="DownHotkeyRow"
                            IsTabStop="True"
                            KeyDown="OnRowKeyDown"
                            LostFocus="OnRowLostFocus"
                            Tag="{x:Bind HotkeysViewModel.Down}"
                            UseSystemFocusVisuals="False">
                            <StackPanel
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="8">
                                <ItemsControl
                                    ItemTemplate="{StaticResource KeycapTemplate}"
                                    ItemsSource="{x:Bind HotkeysViewModel.Down.DisplayTokens, Mode=OneWay}"
                                    Visibility="{x:Bind HotkeysViewModel.Down.ShowKeycaps, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                                <TextBlock
                                    x:Uid="Hotkey_Listening"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Visibility="{x:Bind HotkeysViewModel.Down.IsRecording, Mode=OneWay}" />
                                <Button Click="OnDownEditClick" ToolTipService.ToolTip="Change shortcut">
                                    <FontIcon
                                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                                        FontSize="14"
                                        Glyph="&#xE70F;" />
                                </Button>
                            </StackPanel>
                        </ContentControl>
                    </tk:SettingsCard>
                </StackPanel>

                <!-- Footer: a Settings shortcut in the bottom-right corner. A standard button (visible
                     fill + border at rest) so it reads against the Mica background without hovering. -->
                <Button
                    Margin="0,16,0,16"
                    HorizontalAlignment="Right"
                    Click="OnSettingsClick">
                    <StackPanel
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Spacing="8">
                        <FontIcon
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            FontSize="16"
                            Glyph="&#xE713;" />
                        <TextBlock x:Uid="Main_SettingsButton" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </ScrollViewer>

</Page>
