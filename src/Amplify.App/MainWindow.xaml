<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Amplify.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Amplify.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Amplify"
    mc:Ignorable="d">

    <!--
        TEMPORARY walking-skeleton UI: a Client ID field and a Connect button that exercise the PKCE
        sign-in end to end. This is throwaway scaffolding — it is replaced by the onboarding screen
        (which captures the Client ID) and the connected status card once those features land.
    -->
    <Grid>
        <StackPanel
            Width="360"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="12">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Amplify" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="Phase 0 connect test (temporary)" />
            <TextBox
                x:Name="ClientIdBox"
                Header="Spotify Client ID"
                PlaceholderText="Paste your Spotify app's Client ID" />
            <Button
                x:Name="ConnectButton"
                Click="OnConnectClick"
                Content="Connect Spotify" />
            <TextBlock
                x:Name="StatusText"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource BodyTextBlockStyle}"
                TextWrapping="Wrap" />

            <!--  Shown once connected: reads/sets the active device's volume to prove the slice end to end.  -->
            <StackPanel
                x:Name="VolumePanel"
                Spacing="8"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="VolumeText"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="Volume —" />
                <TextBlock
                    x:Name="DeviceText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button
                        x:Name="VolumeDownButton"
                        Click="OnVolumeDownClick"
                        Content="&#xE71F;"
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        ToolTipService.ToolTip="Volume down" />
                    <Button
                        x:Name="VolumeUpButton"
                        Click="OnVolumeUpClick"
                        Content="&#xE710;"
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        ToolTipService.ToolTip="Volume up" />
                    <Button
                        x:Name="RefreshButton"
                        Click="OnRefreshClick"
                        Content="Refresh" />
                </StackPanel>
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="Global hotkeys: Ctrl+Alt+Up / Ctrl+Alt+Down (work in the background)."
                    TextWrapping="Wrap" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
