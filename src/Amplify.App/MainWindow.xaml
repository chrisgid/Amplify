<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Amplify.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Amplify.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Amplify"
    mc:Ignorable="d">

    <!--
        A bare window with the default system title bar and placeholder content. The Mica backdrop,
        custom title bar (logo + caption-button insets), and screen routing are added later.
    -->
    <Grid>
        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Style="{StaticResource TitleTextBlockStyle}"
            Text="Amplify" />
    </Grid>
</Window>
