<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Amplify.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Amplify.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Amplify"
    mc:Ignorable="d">

    <!--
        The shell: a Mica window with a custom title bar (logo + name) above a Frame that hosts the
        three top-level screens. The title bar stays fixed while each screen scrolls its own content.
        The backdrop and title-bar extension are configured in code-behind (they can't be set in XAML).
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="Amplify">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/Square44x44Logo.scale-200.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <Frame x:Name="ContentFrame" Grid.Row="1">
            <Frame.ContentTransitions>
                <TransitionCollection>
                    <NavigationThemeTransition />
                </TransitionCollection>
            </Frame.ContentTransitions>
        </Frame>
    </Grid>
</Window>
