<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Amplify.App.Controls.SectionHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        A section title with an optional subtitle directly beneath it. The subtitle sits under the
        title with no gap beyond line height. The margin bakes in the whole section rhythm: 16px above
        to separate it from the section before, a 1px left inset, and 6px below (which, combined with
        the host panel's 4px spacing, gives the standard gap before the section's first card) — so
        callers just drop the control in without setting their own margins, whether or not a subtitle
        is present.
    -->
    <StackPanel Margin="1,16,0,6">
        <TextBlock
            FontWeight="SemiBold"
            Style="{StaticResource BodyStrongTextBlockStyle}"
            Text="{x:Bind Title, Mode=OneWay}" />
        <!-- Collapses to zero height when no subtitle is supplied, so title-only sections are unaffected. -->
        <ContentPresenter Content="{x:Bind Subtitle, Mode=OneWay}" />
    </StackPanel>
</UserControl>
